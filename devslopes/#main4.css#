/*however, this is taking my smaller image and repeating it. 
Browser doesn't know what to do with your small image*/
body
{
	background-image: url(space.jpg);
	/*this makes it not repeat! yay! but now there's whitespace.. */
	background-repeat: no-repeat;
	/*this is specific to using image we're working with. 
	now it fills view port of browser*/
	background-size: cover;
	/*we can take these background properties and add them 
	to additional elements. */
}


